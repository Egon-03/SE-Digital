# Copia questo file in .env.local per lo sviluppo locale.
# Senza queste variabili il sito funziona comunque, usando un "database"
# mock in localStorage (vedi src/lib/repository.ts) — utile per sviluppare
# e per la demo pubblica su GitHub Pages finché Supabase non è collegato.

# URL e chiave anonima del progetto Supabase (Impostazioni progetto > API).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Password condivisa per l'area di moderazione (/moderazione).
# Gate solo lato client: adatto per questa fase iniziale, non per contenuti
# sensibili. Va sostituito da un vero sistema di ruoli in fase 2.
VITE_MODERATION_PASSWORD=
